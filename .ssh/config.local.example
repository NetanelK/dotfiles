# Org-specific SSH hosts
# Copy to ~/.ssh/config.local and fill in values

# Example: jump host
# Host bastion
#     HostName bastion.company.com
#     User your-username
#     IdentityFile ~/.ssh/company-key.pem
#     ForwardAgent yes

# Example: internal hosts via bastion
# Host internal-*
#     ProxyJump bastion
#     User your-username

# Example: VPN/zero-trust gateway
# Host prod staging
#     HostName ssh.gateway.company.com
#     User your-username
#     IdentityFile ~/.ssh/company-key.pem
#     ServerAliveInterval 120

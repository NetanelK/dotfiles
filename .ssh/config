Include ~/.dstack/ssh/config
  Host 100.53.144.84
    HostName 100.53.144.84
    IdentityFile ~/diarize-timeline-key.pem
    User ubuntu

Host 3.253.26.234
    HostName 3.253.26.234
    IdentityFile ~/Downloads/netanel.pem
    User ubuntu

Host frp1
    User frp1-linadmin-devops
    
Host frq1
    User frq1-linadmin-devops
    
Host nvp1
    User nvp1-linadmin-devops
    
Host nvq1
    User nvq1-linadmin-ec2-user
    
Host central
    User central-linadmin
    
Host nvd1
    User nvd1-linadmin-ec2-user
    
Host nva2
    User nva2-linadmin-devops

Host nvq2 nvq2-socks
    User nvq2-linadmin-devops
    
Host irp2
    User irp2-linadmin-devops
    
Host frp2
    User frp2-linadmin-devops
    
Host terraform
    User central-terraform
    RemoteCommand sudo su -
    

# SSH over Session Manager
Host i-* mi-*
    ProxyCommand sh -c "aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
# DevSpace End app.ovp-tools.devspace

Host frp1 frq1 nvp1 nvq1 central nvd1 nva2 nvq2 irp2 frp2 terraform
    ServerAliveInterval 120
    UseKeychain yes
    RequestTTY yes
    RemoteCommand sudo su - netanelk
    IdentityFile ~/.ssh/checkpoint.pem
    ExitOnForwardFailure yes
    HostName ssh.us-2.checkpoint.security

Host frp1-socks frq1 nvp1 nvq1 central nvd1 nva2 nvq2-socks irp2 frp2 terraform
    ServerAliveInterval 60
    ServerAliveCountMax 5
    UseKeychain yes
    ExitOnForwardFailure yes
    RequestTTY no
    IdentityFile ~/.ssh/checkpoint.pem
    HostName ssh.us-2.checkpoint.security

# Created by AWS Toolkit for VSCode. https://github.com/aws/aws-toolkit-vscode
Host aws-ec2-*
    ForwardAgent yes
    AddKeysToAgent yes
    StrictHostKeyChecking accept-new
    ProxyCommand '/Users/netanel.kadosh/Library/Application Support/Code/User/globalStorage/amazonwebservices.aws-toolkit-vscode/ec2_connect' '%h'
    IdentitiesOnly yes
    IdentityFile "'/Users/netanel.kadosh/Library/Application Support/Code/User/globalStorage/amazonwebservices.aws-toolkit-vscode/aws-ec2-key'"
    User '%r'

Host codebuild-sandbox-ssh*
    StrictHostKeyChecking no
    LogLevel INFO
    ForwardAgent yes
    ControlMaster auto
    ControlPersist 10m
    ProxyCommand sh -c "/Users/netanel.kadosh/.aws/codebuild-dev-env/codebuild-sandbox-connect.sh %n"

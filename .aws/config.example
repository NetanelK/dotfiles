# AWS profiles config
# Copy to ~/.aws/config and fill in values
# Uses saml2aws for Okta/SAML federation

# [profile main]
# credential_process = saml2aws login -a main --credential-process --force --skip-prompt --credentials-file=$HOME/.aws/saml2aws/credentials
# region = us-east-1

# [profile dev]
# credential_process = saml2aws login -a dev --credential-process --force --skip-prompt --credentials-file=$HOME/.aws/saml2aws/credentials
# region = us-east-1

# [profile terraform]
# source_profile = main
# role_arn = arn:aws:iam::123456789012:role/terraform-admin-role

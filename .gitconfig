[user]
	name = Netanel Kadosh
[credential]
	helper = osxkeychain
	helper = 
	helper = /usr/local/share/gcm-core/git-credential-manager
[core]
	excludesfile = ~/.gitignore
[pull]
	rebase = true
[rebase]
	autostash = true
[alias]
	rph = rev-parse --short HEAD
[credential "https://dev.azure.com"]
	useHttpPath = true
[include]
	path = ~/.gitconfig.local

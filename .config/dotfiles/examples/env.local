# Org-specific aliases and env
# Copy to ~/.env.local and fill in values

# AWS console shortcut (saml2aws)
# alias awsconsole="saml2aws console --session-duration=14400 --credentials-file=$HOME/.aws/saml2aws/credentials -a "

# Org-specific kubectl contexts
# alias kprod="kubectl config use-context prod"
# alias kstg="kubectl config use-context staging"
